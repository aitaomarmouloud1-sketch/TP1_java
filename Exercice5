package partie2;

import java.util.Scanner;
import java.util.Arrays;
public class Exercice5 {

	public static void main(String[] args) {
		Scanner sc=new Scanner(System.in);
		System.out.println("donnez la taille de tableaux ....");
		int N =sc.nextInt();
		int []tab=new int[N];
		for(int i=0;i<N;i++) {
			System.out.println("saisi element  "+(i+1));
			tab[i]=sc.nextInt();
		}
		System.out.println("afichage des elements de tableaux");
		System.out.println(Arrays.toString(tab));
		sc.close();

	}

}
