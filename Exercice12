package partie4;

import java.util.Scanner;

public class Exercice12 {

	public static void main(String[] args) {
		Scanner sc =new Scanner(System.in);
		System.out.print("saisi une chaine de caractéres....:");
		String s=sc.nextLine();
		int conteur=0;
		char re;
		for	(int i=0;i<s.length();i++) {
			re=s.charAt(i);
			if(re!=' ') {
				conteur++;
			}
				
		}
			System.out.println("le nombre de voyelles de c'est chaine de caractéres est :"+conteur);
			sc.close();
	}

}
