package partie1;
import java.util.Scanner;
public class Exercice4 {
	public static void main(String[] args) {
		Scanner sc=new Scanner(System.in);
		System.out.println("saisi un nb pour calclule la somme des N premiers entiers :");
		int n=sc.nextInt();
		int i=1;
		int s=0;
		while(i<=n) {
			s+=i;
			i++;
			
		}
		System.out.println(" la somme des "+n+" premiers entiers: "+s);
		sc.close();
	}

}
